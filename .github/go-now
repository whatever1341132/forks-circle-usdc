#!/bin/bash

set -e

echo "AUTO REPAIR ENGINE START"

LEVEL=${1:-3}
TIMESTAMP=$(date +%s)
BACKUP_DIR=".backup_$TIMESTAMP"

mkdir -p "$BACKUP_DIR"

git stash push -m "auto-repair-$TIMESTAMP" || true

find . -type f \( -name "*.py" -o -name "*.js" -o -name "*.ts" -o -name "*.sh" \) | while read -r file; do
  mkdir -p "$BACKUP_DIR/$(dirname "$file")"
  cp "$file" "$BACKUP_DIR/$file"
done

if [ "$LEVEL" -ge 1 ]; then
  find . -type f -name "*.py" | while read -r file; do
    sed -i 's/== None/is None/g' "$file" 2>/dev/null || true
    sed -i 's/!= None/is not None/g' "$file" 2>/dev/null || true
  done
fi

if [ "$LEVEL" -ge 3 ]; then
  find . -type f -name "*.py" | while read -r file; do
    sed -i 's/print (/print(/g' "$file" 2>/dev/null || true
  done
fi

python3 -m compileall . >/dev/null 2>&1

if python3 main.py; then

  git add .
  git commit -m "auto repair level $LEVEL $TIMESTAMP" || true
  git push || true

  echo "SUCCESS"

else

  git reset --hard HEAD || true
  git stash pop || true

  find "$BACKUP_DIR" -type f | while read -r file; do
    original="${file/$BACKUP_DIR/}"
    cp "$file" "$original"
  done

  echo "ROLLBACK COMPLETE"
  exit 1
fi

echo "AUTO REPAIR ENGINE END"